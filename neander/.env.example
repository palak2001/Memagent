# Copy to .env and fill in your key(s).

# --- Provider selection ---
# LLM_PROVIDER=openai       # default
# LLM_PROVIDER=gemini       # switch to Google Gemini

# --- OpenAI (default provider) ---
OPENAI_API_KEY=sk-...

# --- Gemini (set LLM_PROVIDER=gemini to activate) ---
# GEMINI_API_KEY=...

# --- Model overrides (optional) ---
# CHAT_MODEL=gpt-4o
# EXTRACT_MODEL=gpt-4o-mini
# For Gemini: CHAT_MODEL=gemini-1.5-flash, EXTRACT_MODEL=gemini-1.5-flash

# --- Storage ---
# DB_PATH=neander_memory.db

# --- Embedding backend ---
# EMBED_BACKEND=auto        # auto: sentence-transformers with hash fallback
# EMBED_BACKEND=hash        # fast offline fallback (tests use this)
